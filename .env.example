# Get a key from https://aistudio.google.com/app/apikey
# Required only for the two LLM-judged exercises (type-answer, fill-blank).
# Without it, those exercises fall back to tolerant string matching.
# Also used by the playground image generator (POST /api/playground/generate-image),
# which has no fallback and returns an error when this is unset.
GOOGLE_API_KEY=
OPENAI_API_KEY=
# Optional: override the Gemini image-generation model used by the playground.
# Default is gemini-3.1-flash-image (~$0.067 per 1024x1024 image).
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
